          </object>
          <packing><property name="expand">False</property><property name="fill">False</property><property name="padding">6</property><property name="position">3</property></packing>
        </child>
        <child>
          <object class="GtkBox" id="sg_btn_row">
            <property name="visible">True</property>
            <property name="can-focus">False</property>
            <property name="halign">center</property>
            <property name="spacing">10</property>
            <child>
              <object class="GtkButton" id="sg_newhand">
                <property name="name">sg-newhand</property><property name="visible">True</property><property name="can-focus">True</property><property name="receives-default">True</property>
                <property name="label" translatable="yes">New Hand</property>
                <style><class name="sg-btn"/></style>
              </object>
              <packing><property name="expand">False</property><property name="fill">False</property><property name="position">0</property></packing>
            </child>
            <child>
              <object class="GtkButton" id="sg_restart">
                <property name="name">sg-restart</property><property name="visible">True</property><property name="can-focus">True</property><property name="receives-default">True</property>
                <property name="label" translatable="yes">Restart</property>
                <style><class name="sg-btn"/></style>
              </object>
              <packing><property name="expand">False</property><property name="fill">False</property><property name="position">1</property></packing>
            </child>
            <child>
              <object class="GtkButton" id="sg_addbots">
                <property name="name">sg-addbots</property><property name="visible">True</property><property name="can-focus">True</property><property name="receives-default">True</property>
                <property name="label" translatable="yes">Add Bots</property>
                <style><class name="sg-btn"/></style>
              </object>
              <packing><property name="expand">False</property><property name="fill">False</property><property name="position">2</property></packing>
            </child>
            <child>
              <object class="GtkButton" id="sg_quit">
                <property name="name">sg-quit</property><property name="visible">True</property><property name="can-focus">True</property><property name="receives-default">True</property>
                <property name="label" translatable="yes">Quit</property>
                <style><class name="sg-btn"/></style>
              </object>
              <packing><property name="expand">False</property><property name="fill">False</property><property name="position">3</property></packing>
