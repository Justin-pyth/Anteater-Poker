            <child><object class="GtkLabel"><property name="name">sg-cell</property><property name="visible">True</property><property name="can-focus">False</property><property name="halign">start</property><property name="label">6</property></object><packing><property name="left-attach">0</property><property name="top-attach">6</property></packing></child>
            <child><object class="GtkLabel" id="seat_name_5"><property name="name">sg-cell</property><property name="visible">True</property><property name="can-focus">False</property><property name="halign">start</property><property name="label">—</property></object><packing><property name="left-attach">1</property><property name="top-attach">6</property></packing></child>
